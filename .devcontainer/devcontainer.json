{
  "name": "AIF-C01 Lab 1.4 - Servicios AWS AI",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.fontSize": 14,
        "editor.wordWrap": "on",
        "files.autoSave": "afterDelay",
        "workbench.startupEditor": "readme",
        "security.workspace.trust.enabled": false
      }
    }
  },

  "postCreateCommand": "pip install boto3 pandas requests jupyter ipython && (curl -fsSL https://code-server.dev/install.sh | sh -s -- --method=standalone --prefix=/home/vscode/.local 2>/dev/null || true)",
  "postStartCommand": "/home/vscode/.local/bin/code-server --auth none --port 13337 --host 0.0.0.0 > /tmp/code-server.log 2>&1 &",
  "postAttachCommand": "echo 'Lab environment ready! Open ejercicios/ to begin.'",

  "containerEnv": {
    "AWS_DEFAULT_REGION": "us-east-1",
    "PYTHONDONTWRITEBYTECODE": "1",
    "LAB_NAME": "Servicios AWS AI",
    "LAB_BRIDGE_ENABLED": "true"
  },

  "hostRequirements": {
    "memory": "2gb",
    "cpus": 1
  },

  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/lab"
}
